{
    "name": "ramblex-backend",
    "version": "1.0.0",
    "type": "module",
    "main": "index.mjs",
    "sideEffects": false,
    "engines": {
        "node": "24"
    },
    "scripts": {
        "deploy:functions": "firebase deploy --only functions",
        "deploy:textPrompt": "firebase deploy --only functions:textPrompt",
        "deploy:imageAnnotation": "firebase deploy --only functions:imageAnnotation",
        "deploy:imageRecognition": "firebase deploy --only functions:imageRecognition",
        "deploy:textToSpeech": "firebase deploy --only functions:textToSpeech",
        "deploy:deleteAccount": "firebase deploy --only functions:deleteAccount",
        "deploy:onUserProfileUpdate": "firebase deploy --only functions:onUserProfileUpdate",
        "deploy:resolvePlaceImage": "firebase deploy --only functions:resolvePlaceImage",
        "deploy:resolveSearchAnchor": "firebase deploy --only functions:resolveSearchAnchor",
        "deploy:resolveGeoLocationPopular": "firebase deploy --only functions:resolveGeoLocationPopular",
        "deploy:resolveNearbyPlaces": "firebase deploy --only functions:resolveNearbyPlaces",
        "deploy:resolveGlobalPlacesSearch": "firebase deploy --only functions:resolveGlobalPlacesSearch",
        "deploy:resolvePlaceCity": "firebase deploy --only functions:resolvePlaceCity",
        "deploy:firestore": "firebase deploy --only firestore",
        "deploy:storage": "firebase deploy --only storage",
        "serve": "firebase emulators:start --only functions",
        "logs": "firebase functions:log",
        "test": "vitest run",
        "test:watch": "vitest",
        "cleanup:bad-image-negatives": "node scripts/delete-bad-place-image-negatives.mjs --dry-run --clear-explore --credentials scripts/guidex-afc30-2758ce305a68.json"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.6.0",
        "firebase-tools": "^15.22.3",
        "globals": "^17.7.0",
        "vitest": "^4.1.9"
    },
    "dependencies": {
        "firebase-admin": "^13.10.0",
        "firebase-functions": "^7.2.5",
        "openai": "^6.45.0",
        "sharp": "^0.35.2"
    }
}
