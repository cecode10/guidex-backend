rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }

    // Who may follow this user (mirrors app `ProfilePrivacyService`).
    function effectiveWhoCanFollowMe(data) {
      let raw = data == null ? 'everyone' : (
        (data.settings is map
            && 'whoCanFollowMe' in data.settings
            && data.settings.whoCanFollowMe is string)
          ? data.settings.whoCanFollowMe
          : (data.keys().hasAny(['whoCanFollowMe']) && data.whoCanFollowMe is string
              ? data.whoCanFollowMe
              : 'everyone')
      );
      return (raw == 'everyone' || raw == 'people_i_follow' || raw == 'no_one') ? raw : 'everyone';
    }

    // [followerId] adds users/{followerId}/friends/{targetId}; target must allow it.
    function followCreateAllowed(targetUserData, followerId, targetId) {
      let policy = effectiveWhoCanFollowMe(targetUserData);
      return policy == 'everyone'
        || (policy == 'people_i_follow'
            && exists(/databases/$(database)/documents/users/$(targetId)/friends/$(followerId)));
    }

    // Users Collection
    match /users/{userId} {
      // Anyone logged in can read user profiles (needed for search and feed)
      allow read: if isSignedIn();
      // Users can only update their own profile/settings
      allow write: if isSignedIn() && request.auth.uid == userId;

      // Friends Subcollection
      match /friends/{friendId} {
        // Anyone logged in can see who someone follows
        allow read: if isSignedIn();
        allow delete: if isSignedIn() && request.auth.uid == userId;
        allow update: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn()
          && request.auth.uid == userId
          && followCreateAllowed(
            get(/databases/$(database)/documents/users/$(friendId)).data,
            userId,
            friendId
          );
      }

      // Explore bookmarks
      match /bookmarks/{bookmarkId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      // Curated trips built from saved places
      match /trips/{tripId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      // Checkmarks check-ins
      match /checkins/{checkInId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.userId == userId;
        allow delete: if isSignedIn() && request.auth.uid == userId;
        // Signed-in users may update likeCount via like transactions.
        allow update: if isSignedIn();

        match /likes/{likerId} {
          allow read: if isSignedIn();
          allow write: if isSignedIn() && request.auth.uid == likerId;
        }
      }
    }

    // Collection-group queries on any `friends` subcollection
    // (e.g. followers lookup via collectionGroup('friends')).
    match /{document=**}/friends/{friendDocId} {
      allow read: if isSignedIn();
    }

    // Collection-group queries on any `likes` subcollection
    // (e.g. CheckmarksService.ensureLikesBound() via collectionGroup('likes')).
    match /{document=**}/likes/{likeDocId} {
      allow read: if isSignedIn();
    }

    // Posts Collection
    match /posts/{postId} {
      // Anyone logged in can read the feed
      allow read: if isSignedIn();
      // Anyone logged in can create a post
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      // Only the author can delete their post
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      // Updates are generally restricted, except for incrementing like counts (handled via transactions)
      allow update: if isSignedIn();

      // Likes Subcollection
      match /likes/{userId} {
        allow read: if isSignedIn();
        // Users can only add/remove their own likes
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Shared place-image cache. Written exclusively by the
    // `resolvePlaceImage` Cloud Function (Admin SDK bypasses these rules);
    // clients may only read the resolved cover/metadata.
    match /place-images/{placeKey} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Customer Feedback Collection
    match /customer-feedback/{feedbackId} {
      // Anyone logged in can submit feedback
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;

      // No one can read, update, or delete feedback from the client app
      allow read, update, delete: if false;
    }
  }
}
